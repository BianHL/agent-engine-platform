# =============================================================================
# Agent Engine Platform - 环境变量配置
# =============================================================================
#
# 使用方式:
#   本地开发 (不使用 Docker):  cp .env.example .env     → 修改 *_HOST 为 localhost
#   Docker 部署:               cp .env.docker .env       → 使用 Docker 服务名
#
# 标记为 <PRODUCTION> 的项目在部署到生产环境前必须修改。
# =============================================================================

# ---- 通用 ----
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
APP_PORT=8000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# 数据库 (MySQL) - 外部依赖
# =============================================================================
# MySQL 不随 Docker 启动，需单独部署或使用云服务
DATABASE_URL=mysql+aiomysql://root:${DB_PASSWORD:-dev_only}@${DB_HOST:-localhost}:${DB_PORT:-3306}/${DB_NAME:-agent_engine}

DB_HOST=localhost
DB_PORT=3306
DB_NAME=agent_engine
DB_PASSWORD=dev_only                 # <PRODUCTION> 必须修改
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_ECHO=false

# =============================================================================
# Redis - 外部依赖
# =============================================================================
# Redis 不随 Docker 启动，需单独部署或使用云服务
REDIS_URL=redis://:${REDIS_PASSWORD:-dev_only}@${REDIS_HOST:-localhost}:${REDIS_PORT:-6379}/0

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev_only              # <PRODUCTION> 必须修改

# =============================================================================
# Celery (使用 Redis 作为消息代理)
# =============================================================================
# 如果为空，则自动从 REDIS_URL 派生（db=2 用于代理，db=3 用于结果后端）
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# =============================================================================
# Milvus (向量数据库) - 外部依赖
# =============================================================================
# Milvus 不随 Docker 启动，需单独部署或使用云服务
MILVUS_HOST=localhost                # 替换为实际 Milvus 地址
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=aep_

# =============================================================================
# Neo4j (图数据库)
# =============================================================================
# 始终作为容器运行（不受 profile 控制）
NEO4J_URI=bolt://${NEO4J_HOST:-localhost}:${NEO4J_BOLT_PORT:-7687}
NEO4J_HOST=localhost                 # Docker: neo4j | 本地: localhost
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev_only              # <PRODUCTION> 必须修改
NEO4J_DATABASE=neo4j

# =============================================================================
# Elasticsearch - 外部依赖
# =============================================================================
# ES 不随 Docker 启动，需单独部署或使用云服务
ES_HOSTS=http://${ES_HOST:-localhost}:${ES_PORT:-9200}
ES_HOST=localhost
ES_PORT=9200
ES_INDEX_PREFIX=aep_
ES_HEAP_MIN=512m
ES_HEAP_MAX=512m
ES_USERNAME=
ES_PASSWORD=

# =============================================================================
# JWT / 认证  <PRODUCTION> 必须修改
# =============================================================================
SECRET_KEY=dev-only-change-me        # <PRODUCTION> python -c "import secrets; print(secrets.token_urlsafe(32))"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# 加密  <PRODUCTION> 必须修改
# =============================================================================
ENCRYPTION_KEY=dev-only-change-me    # <PRODUCTION> python -c "import secrets; print(secrets.token_urlsafe(32))"

# =============================================================================
# 密码学后端
# =============================================================================
CRYPTO_BACKEND=standard              # standard (默认) | gm (国密)

# =============================================================================
# MCP Server 认证
# =============================================================================
MCP_API_KEY=                         # MCP 客户端必须发送此密钥进行认证

# =============================================================================
# 跨域资源共享 (CORS)
# =============================================================================
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]

# =============================================================================
# 速率限制
# =============================================================================
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT=5                   # 每个窗口的最大登录尝试次数
LOGIN_RATE_WINDOW=60                 # 窗口时间（秒）

# =============================================================================
# 上传 / 文件
# =============================================================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# =============================================================================
# 工作流引擎
# =============================================================================
WORKFLOW_GLOBAL_TIMEOUT=300          # 全局超时（秒）
WORKFLOW_CODE_SANDBOX_TIMEOUT=30     # 每个代码节点的超时（秒）
WORKFLOW_CODE_MAX_OUTPUT=5000        # 代码节点的最大输出字符数

# =============================================================================
# 安全引擎
# =============================================================================
SAFETY_INPUT_CHECK_ENABLED=true
SAFETY_OUTPUT_CHECK_ENABLED=true

# =============================================================================
# 企业微信 (WeCom) 集成
# =============================================================================
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_REDIRECT_URI=
WECOM_WEBHOOK_URL=

# =============================================================================
# Nginx (仅 Docker 环境)
# =============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# =============================================================================
# 前端
# =============================================================================
# 浏览器端请求后端的地址（Docker 和本地开发通常一致: localhost:8000）
NEXT_PUBLIC_API_URL=http://localhost:8000
