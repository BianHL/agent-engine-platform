# =============================================================================
# Agent Engine Platform - Docker 环境变量
# =============================================================================
# Docker Compose 自动读取此文件用于:
#   1. YAML 变量替换 (如 ${DB_PASSWORD})
#   2. 容器环境变量注入 (env_file 指令)
#
# 复制为 .env:  cp .env.docker .env
# 标记为 <PRODUCTION> 的项目在部署到生产环境前必须修改。
# =============================================================================

# ---- 通用 ----
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_PORT=8000
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ---- MySQL (Docker 服务名: mysql) ----
DATABASE_URL=mysql+aiomysql://root:${DB_PASSWORD:-dev_only}@mysql:3306/${DB_NAME:-agent_engine}
DB_HOST=mysql
DB_PORT=3306
DB_NAME=agent_engine
DB_PASSWORD=dev_only                 # <PRODUCTION> 必须修改
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_ECHO=false

# ---- Redis (Docker 服务名: redis) ----
REDIS_URL=redis://:${REDIS_PASSWORD:-dev_only}@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=dev_only              # <PRODUCTION> 必须修改

# ---- Celery ----
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# ---- Milvus (Docker 服务名: milvus-standalone) ----
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=aep_

# ---- Neo4j (Docker 服务名: neo4j) ----
NEO4J_URI=bolt://neo4j:7687
NEO4J_HOST=neo4j
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=dev_only              # <PRODUCTION> 必须修改
NEO4J_DATABASE=neo4j

# ---- Elasticsearch (Docker 服务名: elasticsearch) ----
ES_HOSTS=http://elasticsearch:9200
ES_HOST=elasticsearch
ES_PORT=9200
ES_INDEX_PREFIX=aep_
ES_HEAP_MIN=512m
ES_HEAP_MAX=512m
ES_USERNAME=
ES_PASSWORD=

# ---- JWT / 认证 ----
SECRET_KEY=dev-only-change-me        # <PRODUCTION> 必须修改
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- 加密 ----
ENCRYPTION_KEY=dev-only-change-me    # <PRODUCTION> 必须修改

# ---- 密码学后端 ----
CRYPTO_BACKEND=standard

# ---- MCP Server ----
MCP_API_KEY=

# ---- CORS ----
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-Request-ID"]

# ---- 速率限制 ----
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=60

# ---- 上传 ----
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# ---- 工作流 ----
WORKFLOW_GLOBAL_TIMEOUT=300
WORKFLOW_CODE_SANDBOX_TIMEOUT=30
WORKFLOW_CODE_MAX_OUTPUT=5000

# ---- 安全 ----
SAFETY_INPUT_CHECK_ENABLED=true
SAFETY_OUTPUT_CHECK_ENABLED=true

# ---- 企业微信 ----
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_REDIRECT_URI=
WECOM_WEBHOOK_URL=

# ---- Nginx ----
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ---- 前端 ----
NEXT_PUBLIC_API_URL=http://localhost:8000
